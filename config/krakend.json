{
  "version": 3,
  "name": "Store Manager API Gateway",
  "timeout": "5s",
  "cache_ttl": "300s",
  "output_encoding": "json",
  "port": 8080,
  "endpoints": [
    {
      "endpoint": "/payments-api/payments",
      "method": "POST", 
      "backend": [
        {
          "url_pattern": "/payments",
          "_change_for_deployment": "host is http://payments_api:5009 // http://10.194.32.180:5009",
          "host": ["http://10.194.32.180:5009"], 
          "timeout": "5s"
        }
      ]
    },
    {
      "endpoint": "/payments-api/payments/process/{payment_id}",
      "method": "POST", 
      "backend": [
        {
          "url_pattern": "/payments/process/{payment_id}",
          "_change_for_deployment": "host is http://payments_api:5009 // http://10.194.32.180:5009",
          "host": ["http://10.194.32.180:5009"],
          "timeout": "5s"
        }
      ]
    },
    {
      "endpoint": "/store-manager-api/orders",
      "method": "POST",
      "backend": [
        {
          "url_pattern": "/orders",
          "host": ["http://store_manager:5000"]
        }
      ],
      "extra_config": {
        "qos/ratelimit/router": {
          "max_rate": 200,
          "every": "1m"
        }
      }
  },
  {
    "endpoint": "/store-manager-api/orders",
    "method": "PUT",
    "backend": [
      {
        "url_pattern": "/orders",
        "host": ["http://store_manager:5000"]
      }
    ]
  },
    {
    "endpoint": "/store-manager-api/test/slow/{delay}",
    "method": "GET",
    "backend": [
      {
        "url_pattern": "/test/slow/{delay}",
        "host": ["http://store_manager:5000"],
        "timeout": "5s"
      }
    ]
  }
  ]
}